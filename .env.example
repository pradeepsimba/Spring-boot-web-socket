# Copy this file to .env and fill in real values. .env is gitignored — never commit real credentials.
SPRING_DATASOURCE_URL=jdbc:postgresql://host.docker.internal:5432/algo?sessionTimezone=Asia/Kolkata
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=changeme

# Comma-separated list of allowed WebSocket origins, or * for dev only. Restrict this in production.
WEBSOCKET_ALLOWED_ORIGINS=*
